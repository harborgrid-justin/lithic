# Environment
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/lithic?schema=public
DIRECT_URL=postgresql://username:password@localhost:5432/lithic?schema=public

# NextAuth.js (Authentication)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production

# JWT
JWT_SECRET=your-jwt-secret-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption Keys (AES-256 for PHI encryption)
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-in-production
ENCRYPTION_IV_LENGTH=16

# AWS S3 (Medical Document/Imaging Storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=lithic-healthcare-assets
AWS_S3_DICOM_BUCKET=lithic-dicom-storage

# Redis (Session & Cache)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email (SMTP for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@lithic.health
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@lithic.health

# Twilio (SMS for appointment reminders)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Pusher (Real-time updates)
NEXT_PUBLIC_PUSHER_APP_KEY=your-pusher-app-key
PUSHER_APP_ID=your-pusher-app-id
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=us2

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# HL7 Integration
HL7_INTERFACE_HOST=localhost
HL7_INTERFACE_PORT=2575
HL7_SENDING_APPLICATION=LITHIC
HL7_SENDING_FACILITY=LITHIC_MAIN

# FHIR Server (Optional - for interoperability)
FHIR_SERVER_URL=https://fhir.lithic.health/r4
FHIR_SERVER_AUTH_TOKEN=your-fhir-server-token

# Surescripts (ePrescribing)
SURESCRIPTS_ACCOUNT_ID=your-surescripts-account-id
SURESCRIPTS_API_KEY=your-surescripts-api-key
SURESCRIPTS_ENDPOINT=https://preproduction.surescripts.net

# Clearinghouse (Claims submission)
CLEARINGHOUSE_API_URL=https://api.clearinghouse.com
CLEARINGHOUSE_USERNAME=your-username
CLEARINGHOUSE_PASSWORD=your-password
CLEARINGHOUSE_SENDER_ID=your-sender-id

# PACS Integration (Medical Imaging)
PACS_AE_TITLE=LITHIC_PACS
PACS_HOST=localhost
PACS_PORT=11112
PACS_STORAGE_PATH=/var/lithic/dicom

# Drug Database (for interaction checking)
DRUG_DATABASE_API_KEY=your-drug-database-api-key
DRUG_DATABASE_URL=https://api.drugbank.com

# ICD-10 & CPT Coding API
CODING_API_KEY=your-coding-api-key
CODING_API_URL=https://api.codingsystem.com

# AI / LLM (Claude) — see docs/llm/ for full guidance
# Provider: anthropic (recommended for clinical/PHI workloads), openai, or azure-openai
AI_PROVIDER=anthropic
# Pin a current Claude model ID (see https://platform.claude.com/docs/en/about-claude/models/overview).
# Default to Sonnet 4.6; escalate per-feature to Opus 4.7, or use Haiku 4.5 for bulk/low-latency tasks.
AI_MODEL=claude-sonnet-4-6

# API keys (inject via a secrets manager in production; never commit real values)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Cost & abuse controls (see docs/llm/token-optimization.md and docs/llm/enterprise.md)
AI_RATE_LIMIT_PER_MINUTE=60
AI_RATE_LIMIT_PER_HOUR=1000
AI_MAX_TOKENS_PER_DAY=100000
AI_CACHE_TTL=3600000
AI_CACHE_MAX_SIZE=1000
AI_TIMEOUT=30000
AI_RETRIES=3

# Analytics & Monitoring
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-public-sentry-dsn

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Session Configuration
SESSION_MAX_AGE=900
SESSION_IDLE_TIMEOUT=900
SESSION_ABSOLUTE_TIMEOUT=28800

# Audit Logging
AUDIT_LOG_RETENTION_DAYS=2555
ENABLE_AUDIT_LOGGING=true

# HIPAA Compliance
ENABLE_PHI_ENCRYPTION=true
ENABLE_AUDIT_TRAIL=true
MINIMUM_PASSWORD_LENGTH=12
PASSWORD_EXPIRY_DAYS=90
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=1800

# Feature Flags
ENABLE_PATIENT_PORTAL=true
ENABLE_TELEMEDICINE=false
ENABLE_LAB_INTEGRATION=true
ENABLE_PHARMACY_INTEGRATION=true
ENABLE_IMAGING_INTEGRATION=true

# Development Only
DEBUG_MODE=false
MOCK_EXTERNAL_APIS=false
DISABLE_RATE_LIMITING=false

# ===========================================================================
# Additional service configuration (exact names read by application code)
# ---------------------------------------------------------------------------
# Several services read env-var names that differ from older entries above.
# Set the names in THIS section, or the service will silently fail to connect.
# Inline notes mark where a name supersedes an older one above.
# ===========================================================================

# AWS S3 — application reads S3_BUCKET (supersedes AWS_S3_BUCKET above).
# AWS credentials/region are read automatically by the AWS SDK from
# AWS_REGION / AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (already set above).
S3_BUCKET=lithic-healthcare-assets

# FHIR client / SMART-on-FHIR (supersedes FHIR_SERVER_URL / FHIR_SERVER_AUTH_TOKEN)
FHIR_BASE_URL=https://fhir.lithic.health/r4
NEXT_PUBLIC_FHIR_BASE_URL=https://fhir.lithic.health/r4
FHIR_CLIENT_ID=your-fhir-client-id
FHIR_CLIENT_SECRET=your-fhir-client-secret

# Public base URLs + realtime sockets (read client-side)
# Note: lib/security/sso/saml.ts reads NEXT_PUBLIC_URL; most code uses
# NEXT_PUBLIC_APP_URL (above). Keep them consistent.
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
CORS_ORIGIN=http://localhost:3000

# Web Push (VAPID) — lib/notifications/channels/push.ts
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@lithic.health

# Email channel (lib/notifications/channels/email.ts)
EMAIL_PROVIDER=smtp
EMAIL_FROM_NAME=Lithic Health

# Redis — lib/queue/processor.ts uses discrete host/port/db; other modules use
# REDIS_URL (above). Provide both for full coverage.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Surescripts ePrescribing (supersedes SURESCRIPTS_ACCOUNT_ID / _API_KEY / _ENDPOINT)
SURESCRIPTS_URL=https://preproduction.surescripts.net
SURESCRIPTS_USERNAME=your-surescripts-username
SURESCRIPTS_PASSWORD=your-surescripts-password
SURESCRIPTS_SITE_ID=your-surescripts-site-id

# Claims clearinghouse (supersedes CLEARINGHOUSE_API_URL / _USERNAME / _PASSWORD / _SENDER_ID)
CLEARINGHOUSE_URL=https://api.clearinghouse.com
CLEARINGHOUSE_API_KEY=your-clearinghouse-api-key
CLEARINGHOUSE_SUBMITTER_ID=your-submitter-id

# Insurance eligibility (lib/integrations/eligibility.ts)
ELIGIBILITY_API_URL=https://api.eligibility.com
ELIGIBILITY_API_KEY=your-eligibility-api-key

# Immunization Information System / registry (lib/integrations/immunization-registry.ts)
IIS_URL=https://iis.example-state.gov/api
IIS_API_KEY=your-iis-api-key
IIS_FACILITY_ID=your-iis-facility-id

# Misc service config read by code
AUDIT_SIGNING_KEY=your-audit-log-signing-key
BULK_EXPORT_DIR=/var/lithic/bulk-export
PROVIDER_NPI=0000000000
TWILIO_STATUS_CALLBACK_URL=https://app.lithic.health/api/webhooks/twilio
